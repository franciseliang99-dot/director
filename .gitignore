# 普通 projects 全忽略 (产物 + 用户视频)
# (注:_smoke 是夹具,不被此规则 match,见下方细化)
projects/[!_]*

# _smoke 夹具:manifest + script.json 入仓,产物排
projects/_smoke/images/
projects/_smoke/audio/
projects/_smoke/bgm/
projects/_smoke/renders/
projects/_smoke/logs/
projects/_smoke/.raw/

# 跨目录产物文件类型
*.mp4
*.mp3
*.wav
*.mid
*.jpg
*.jpeg
*.png
*.webp

# 日志 / 临时
*.log
.DS_Store
__pycache__/
*.pyc

# 私密
.env
.env.*
!.env.example
